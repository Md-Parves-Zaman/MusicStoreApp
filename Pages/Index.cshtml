@page
@model MusicStoreApp.Pages.IndexModel
@{
    ViewData["Title"] = "Music Store";
}

<link rel="stylesheet" href="/css/site.css" />

<div class="app-shell">
    <header class="top-bar">
        <div>
            <h1 class="title">Music Store</h1>
        </div>
    </header>

    <section class="toolbar">
        <button id="viewToggle" class="view-toggle">Switch View</button>

        <div class="control-group">
            <label for="lang">Language</label>
            <select id="lang">
                <option value="en-US">English (US)</option>
                <option value="de-DE">German (DE)</option>
            </select>
        </div>

        <div class="control-group">
            <label for="seed">Seed</label>
            <input id="seed" type="number" placeholder="Seed" />
        </div>

        <div class="control-group control-group--wide">
            <label for="likes">Likes <span id="likesValue">3.5</span></label>
            <input id="likes" type="range" min="0" max="10" step="0.1" value="3.5" />
        </div>

        <button id="randomSeedBtn" class="primary-btn">Random Seed</button>
    </section>

    <main class="content-area">
        <section id="tableView" class="card-grid"></section>
        <section id="galleryView" class="gallery-grid" style="display:none;"></section>
    </main>
</div>

<script src="/js/app.js"></script>